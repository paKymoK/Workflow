pipeline {
    agent any

    stages {
        stage('SSH to postgres DB') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'credentials-db',  // lấy từ Jenkins store
                    usernameVariable: 'SSH_USER',           // username → biến SSH_USER
                    passwordVariable: 'SSH_PASS'            // password → biến SSH_PASS
                )]) {
                    sh """
                        echo "Username là: ${SSH_USER}"      // in ra: ubuntu
                        echo "Password là: ${SSH_PASS}"      // in ra: **** (bị che)

                        sshpass -p '${SSH_PASS}' ssh \
                            -o StrictHostKeyChecking=no \
                            ${SSH_USER}@192.168.147.107 \
                            'echo Hello from Server B'
                   """
                }
            } 
        }
    }
}

