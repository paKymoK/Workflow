pipeline {
    agent any
    stages {
        stage('SSH to postgres DB') {
            steps {
                sh '''
                    SSH_USER="thaiha"
                    SSH_PASS="thaiha"
                    HOST="192.168.147.107"

                    echo "Username là: $SSH_USER"
                    echo "Đang kết nối tới $HOST..."

                    sshpass -p "$SSH_PASS" ssh \
                        -o StrictHostKeyChecking=no \
                        -o ConnectTimeout=10 \
                        "$SSH_USER"@"$HOST" \
                        'echo Hello from Server B'
                '''
            }
        }
    }
}
